{
  "outputDirectory": ".",
  "redirects": [
    { "source": "/", "destination": "/index.html", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
